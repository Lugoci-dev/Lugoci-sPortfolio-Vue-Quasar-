{
  "name": "portafolio-s-lugoccidev",
  "version": "0.0.1",
  "description": "A portafolio project",
  "productName": "Lugocci_dev-portafolio",
  "author": "Isaac Daniel <isaitodaiel@gmail.com>",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,vue,css,html,md,json}\" --ignore-path .gitignore",
    "test": "echo \"No test specified\" && exit 0",
    "dev": "quasar dev",
    "build": "quasar build",
    "postinstall": "quasar prepare",
    "deploy": "git fetch origin gh-pages --depth 1 && git branch -D gh-pages 2>/dev/null; git branch gh-pages origin/gh-pages 2>/dev/null; rm -rf /tmp/gh-deploy && git worktree add /tmp/gh-deploy gh-pages && find /tmp/gh-deploy -mindepth 1 -not -path '/tmp/gh-deploy/.git' -not -path '/tmp/gh-deploy/.git/*' -delete && cp -r dist/spa/* /tmp/gh-deploy/ && touch /tmp/gh-deploy/.nojekyll && git -C /tmp/gh-deploy add -A && git -C /tmp/gh-deploy commit -m \"deploy: SPA build from $(git rev-parse --short HEAD)\" && git -C /tmp/gh-deploy push origin gh-pages && rm -rf /tmp/gh-deploy && git worktree prune"
  },
  "dependencies": {
    "@quasar/extras": "^1.16.4",
    "@tailwindcss/postcss": "^4.1.13",
    "axios": "^1.2.1",
    "pinia": "^3.0.1",
    "quasar": "^2.16.0",
    "tailwindcss": "^4.1.13",
    "vue": "3.5.20",
    "vue-i18n": "^11.0.0",
    "vue-router": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@intlify/unplugin-vue-i18n": "^4.0.0",
    "@quasar/app-vite": "^2.1.0",
    "@vue/eslint-config-prettier": "^10.1.0",
    "autoprefixer": "^10.4.2",
    "eslint": "^9.14.0",
    "eslint-plugin-vue": "^10.4.0",
    "gh-pages": "^6.3.0",
    "globals": "^16.4.0",
    "postcss": "^8.4.14",
    "prettier": "^3.3.3",
    "vite-plugin-checker": "^0.10.3",
    "vue-eslint-parser": "^10.2.0"
  },
  "engines": {
    "node": "^28 || ^26 || ^24 || ^22 || ^20",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  }
}
